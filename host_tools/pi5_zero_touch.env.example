# Host stage-0
BOOTFS_PATH=/Volumes/bootfs
BOOTSTRAP_HOSTNAME=lelamp-pi5
BOOTSTRAP_USER=pi
BOOTSTRAP_PASSWORD=replace-me
BOOTSTRAP_WIFI_SSID=
BOOTSTRAP_WIFI_PASSWORD=
BOOTSTRAP_WIFI_COUNTRY=CN
BOOTSTRAP_SSH_PUBLIC_KEY=

# Repo bootstrap
BOOTSTRAP_REPO_URL=https://github.com/wujiajunhahah/lelamp-dev.git
BOOTSTRAP_REPO_BRANCH=main
BOOTSTRAP_REPO_DIR=lelamp-dev

# Pi stage-1
AUTO_ACCEPT_DEFAULTS=1
AUTO_REBOOT=1
LAMP_ID=lelamp
LAMP_PORT=auto
MODE_SCRIPT=smooth_animation.py
RESPEAKER_VARIANT=auto
INSTALL_LELAMP_SERVICE=1
INSTALL_OPENCLAW=1
OPENCLAW_INSTALL_MODE=standard
INSTALL_TAILSCALE=0
RUN_OPENCLAW_ONBOARD=0
RUN_DOWNLOAD_FILES_POSTBOOT=1

# Optional voice secrets
OPENAI_API_KEY=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
