# Host stage-0
BOOTFS_PATH=/Volumes/bootfs
BOOTSTRAP_HOSTNAME=lelamp-pi5
BOOTSTRAP_USER=pi
BOOTSTRAP_PASSWORD=replace-me
BOOTSTRAP_WIFI_SSID=
BOOTSTRAP_WIFI_PASSWORD=
BOOTSTRAP_WIFI_COUNTRY=CN
BOOTSTRAP_SSH_PUBLIC_KEY=

# Repo bootstrap
BOOTSTRAP_REPO_URL=https://github.com/wujiajunhahah/lelamp-dev.git
BOOTSTRAP_REPO_BRANCH=main
BOOTSTRAP_REPO_DIR=lelamp-dev
BOOTSTRAP_NETWORK_TEST_URLS="https://github.com https://api.github.com https://www.baidu.com https://connectivitycheck.gstatic.com/generate_204"
BOOTSTRAP_NETWORK_WAIT_ATTEMPTS=30
BOOTSTRAP_REPO_WAIT_ATTEMPTS=18

# Pi stage-1
AUTO_ACCEPT_DEFAULTS=1
AUTO_REBOOT=1
LAMP_ID=lelamp
LAMP_PORT=auto
MODE_SCRIPT=smooth_animation.py
MODEL_PROVIDER=qwen
MODEL_API_KEY=
MODEL_BASE_URL=https://dashscope.aliyuncs.com/api-ws/v1/realtime
MODEL_NAME=qwen3.5-omni-plus-realtime
MODEL_VOICE=Tina
RESPEAKER_VARIANT=auto
INSTALL_LELAMP_SERVICE=1
INSTALL_OPENCLAW=1
OPENCLAW_INSTALL_MODE=standard
INSTALL_TAILSCALE=0
RUN_OPENCLAW_ONBOARD=0
RUN_DOWNLOAD_FILES_POSTBOOT=1

# Compatibility fallbacks
DASHSCOPE_API_KEY=
QWEN_API_KEY=
ZAI_API_KEY=
OPENAI_API_KEY=

# LiveKit worker credentials
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
