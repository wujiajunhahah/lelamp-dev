# Voice agent model
MODEL_PROVIDER=qwen
MODEL_API_KEY=
MODEL_BASE_URL=https://dashscope.aliyuncs.com/api-ws/v1/realtime
MODEL_NAME=qwen3.5-omni-plus-realtime
MODEL_VOICE=Tina
LELAMP_QWEN_USE_SERVER_VAD=false
LELAMP_AGENT_LANGUAGE=zh-CN
LELAMP_AGENT_OPENING_LINE=灯灯醒了。

# Compatibility fallbacks for existing environments
DASHSCOPE_API_KEY=
QWEN_API_KEY=
ZAI_API_KEY=
OPENAI_API_KEY=

# Optional LiveKit room worker credentials
# Local Pi + ReSpeaker console mode does not require these.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LeLamp hardware identity
LELAMP_ID=lelamp
LELAMP_PORT=/dev/ttyACM0
LELAMP_AUDIO_USER=pi
LELAMP_AUDIO_CARD_INDEX=2
LELAMP_CONSOLE_ENABLE_APM=false
LELAMP_CONSOLE_SPEECH_THRESHOLD_DB=-54
LELAMP_CONSOLE_SILENCE_DURATION_S=0.4
LELAMP_CONSOLE_MIN_SPEECH_DURATION_S=0.2
LELAMP_CONSOLE_COMMIT_COOLDOWN_S=0.75
LELAMP_CONSOLE_OUTPUT_SUPPRESSION_S=0.35
LELAMP_CONSOLE_AUTO_CALIBRATE=true
LELAMP_CONSOLE_CALIBRATION_DURATION_S=1.6
LELAMP_CONSOLE_CALIBRATION_MARGIN_DB=8.0
LELAMP_CONSOLE_START_TRIGGER_S=0.08
LELAMP_VOICE_STATE_PATH=/tmp/lelamp-voice-state.json
HF_LEROBOT_CALIBRATION=/home/pi/.cache/huggingface/lerobot/calibration
LELAMP_FPS=30

# TNKR LeLamp V1 head BOM uses an 8x5 WS2812B matrix = 40 LEDs
LELAMP_LED_COUNT=40
LELAMP_LED_PIN=12
LELAMP_LED_FREQ_HZ=800000
LELAMP_LED_DMA=10
LELAMP_LED_BRIGHTNESS=255
LELAMP_LED_INVERT=false
LELAMP_LED_CHANNEL=0
LELAMP_ENABLE_RGB=true

# Motion and startup behavior
LELAMP_STARTUP_VOLUME=100
LELAMP_STARTUP_RECORDING=wake_up
LELAMP_IDLE_RECORDING=home_safe
LELAMP_HOME_RECORDING=home_safe
LELAMP_USE_HOME_POSE_RELATIVE=true
LELAMP_INTERPOLATION_DURATION=3.0

# Local dashboard
LELAMP_DASHBOARD_HOST=0.0.0.0
LELAMP_DASHBOARD_PORT=8765
LELAMP_DASHBOARD_POLL_MS=400
